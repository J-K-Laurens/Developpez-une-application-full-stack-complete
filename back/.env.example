# Environment Variables Example
# Copy this file to .env and fill with your actual values
# NEVER commit the .env file to version control!

# MySQL Database Configuration
DB_USERNAME=root
DB_PASSWORD=your_secure_mysql_password_here

# JWT Secret Key
# Requirements: At least 32 characters for HS256 algorithm
# Generate a secure key: openssl rand -hex 32
# Or use: https://www.uuidgenerator.net/
JWT_SECRET=your_secure_jwt_secret_key_at_least_32_characters

# Optional: JWT Expiration (milliseconds)
# Default: 86400000 (24 hours)
# JWT_EXPIRATION_MS=86400000

# Optional: Application Environment
# Values: dev, prod
# ENVIRONMENT=dev
